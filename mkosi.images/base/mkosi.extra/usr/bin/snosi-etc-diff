#!/bin/bash
# SPDX-License-Identifier: LGPL-2.1-or-later
# snosi-etc-diff — show how the live /etc differs from the booted image's
# pristine /etc.
#
# On composefs there is no /usr/etc copy (unlike ostree): the pristine
# image /etc sits under the read-only composefs root, shadowed by the
# writable /etc bind mount. A bind mount of / WITHOUT submounts exposes it.
#
# On native A/B images (marker /usr/lib/snosi/native-ab) the root is EROFS
# and live /etc is an overlay whose lowerdir is /.etc.lower on that same
# root; the bind-mount trick would expose /.etc.lower AND an empty /etc
# mountpoint dir at <mnt>/etc, diffing against the wrong tree. Use
# /.etc.lower directly instead — see resolve_pristine().
#
# Classes:
#   M path   modified locally (content, permissions, or symlink target)
#   D path   deleted locally (exists in the image, not in live /etc)
#   A path   added locally (runtime-created; suppressed unless --added)
#
# Usage: snosi-etc-diff [--machine] [--added]
#        snosi-etc-diff PATH...
#        snosi-etc-diff --restore PATH...
#
# With PATH arguments (e.g. /etc/gdm3/daemon.conf), shows the actual
# difference for each path: a unified diff for regular files, symlink
# targets, or permission/ownership lines. Ignore globs do not apply to
# explicitly named paths.
#
# --restore copies the pristine image version of each PATH back over the
# live /etc (content, permissions, ownership). Only paths that exist in
# the image can be restored; locally added paths must be removed by hand.
#
#   --machine   stable "X<TAB>path" lines for scripts, no headers
#   --added     include A entries (noisy: enablement symlinks, machine-id
#               commit, NM connections and other expected runtime state)
#
# Ignore globs (one per line, relative to /etc, # comments) are read from
# /usr/lib/snosi/etc-diff.ignore and, if present, /etc/snosi/etc-diff.ignore.
set -euo pipefail

usage() {
    cat >&2 <<'EOF'
Usage: snosi-etc-diff [--machine] [--added]
       snosi-etc-diff PATH...
       snosi-etc-diff --restore PATH...
EOF
    exit 2
}

MACHINE=0
SHOW_ADDED=0
RESTORE=0
PATHS=()
for arg in "$@"; do
    case "$arg" in
        --machine) MACHINE=1 ;;
        --added) SHOW_ADDED=1 ;;
        --restore) RESTORE=1 ;;
        --*) usage ;;
        *) PATHS+=("$arg") ;;
    esac
done
if [[ $RESTORE -eq 1 ]]; then
    [[ $MACHINE -eq 0 && $SHOW_ADDED -eq 0 && ${#PATHS[@]} -gt 0 ]] || usage
elif [[ ${#PATHS[@]} -gt 0 ]]; then
    [[ $MACHINE -eq 0 && $SHOW_ADDED -eq 0 ]] || usage
fi

# Test hooks (undocumented in --help): when BOTH are set, detection is
# bypassed entirely and the root requirement is relaxed so
# test/snosi-etc-diff-test.sh can drive fixture trees as non-root.
LIVE_ETC=/etc
NATIVE_AB_MARKER=/usr/lib/snosi/native-ab

# Resolve the pristine image /etc tree into $PRISTINE. On native A/B images
# (marker present) the canonical pristine tree is /.etc.lower directly, no
# mount needed. On bootc/composefs, bind-mount / (without submounts) so the
# read-only pristine /etc hidden beneath the live /etc mount becomes
# reachable; this installs an EXIT trap to unmount it.
resolve_pristine() {
    if [[ -e "$NATIVE_AB_MARKER" ]]; then
        if [[ ! -d /.etc.lower ]]; then
            echo "snosi-etc-diff: native A/B marker present but /.etc.lower is missing or not a directory" >&2
            exit 1
        fi
        PRISTINE=/.etc.lower
        return
    fi
    local mnt
    mnt=$(mktemp -d /run/snosi-etc-diff.XXXXXX)
    cleanup() { umount "$mnt" 2>/dev/null || true; rmdir "$mnt" 2>/dev/null || true; }
    trap cleanup EXIT
    mount --bind -o ro / "$mnt" 2>/dev/null || mount --bind / "$mnt"
    PRISTINE="$mnt/etc"
}

if [[ -n "${SNOSI_ETC_DIFF_LIVE_ETC:-}" && -n "${SNOSI_ETC_DIFF_PRISTINE_ETC:-}" ]]; then
    LIVE_ETC="$SNOSI_ETC_DIFF_LIVE_ETC"
    PRISTINE="$SNOSI_ETC_DIFF_PRISTINE_ETC"
else
    [[ $EUID -eq 0 ]] || { echo "snosi-etc-diff: must run as root (bind-mounts /)" >&2; exit 1; }
    resolve_pristine
fi

IGNORE_PATTERNS=()
for f in /usr/lib/snosi/etc-diff.ignore "$LIVE_ETC/snosi/etc-diff.ignore"; do
    [[ -f "$f" ]] || continue
    while IFS= read -r line; do
        line="${line%%#*}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -n "$line" ]] && IGNORE_PATTERNS+=("$line")
    done < "$f"
done

ignored() { # relative path
    local p="$1" pat
    for pat in "${IGNORE_PATTERNS[@]}"; do
        # shellcheck disable=SC2254
        case "$p" in $pat) return 0 ;; esac
    done
    return 1
}

# ---- path mode: show or restore explicitly named paths -------------------

normalize() { # /etc/foo, etc/foo, foo, ./foo -> foo
    local p="$1"
    p="${p#/etc/}"; p="${p#etc/}"; p="${p#./}"; p="${p%/}"
    if [[ -z "$p" || "$p" == /* || "$p" == .. || "$p" == ../* || "$p" == */../* || "$p" == */.. ]]; then
        echo "snosi-etc-diff: not a path under /etc: $1" >&2; return 1
    fi
    printf '%s' "$p"
}

show_path() { # relative path; prints the actual difference
    local p="$1" a="$PRISTINE/$1" b="$LIVE_ETC/$1"
    if [[ ! -e "$a" && ! -L "$a" && ! -e "$b" && ! -L "$b" ]]; then
        echo "snosi-etc-diff: /etc/$p: not in the image or the live /etc" >&2
        return 1
    fi
    if [[ ! -e "$b" && ! -L "$b" ]]; then
        echo "D /etc/$p (deleted locally; --restore recreates it)"
        [[ -f "$a" ]] && diff -u --label "image:/etc/$p" --label "live:(deleted)" "$a" /dev/null || true
        return 0
    fi
    if [[ ! -e "$a" && ! -L "$a" ]]; then
        echo "A /etc/$p (not in the image; added at runtime)"
        [[ -f "$b" ]] && diff -u --label "image:(absent)" --label "live:/etc/$p" /dev/null "$b" || true
        return 0
    fi
    if [[ -L "$a" || -L "$b" ]]; then
        local ta tb
        ta=$(readlink "$a" 2>/dev/null || echo "(not a symlink)")
        tb=$(readlink "$b" 2>/dev/null || echo "(not a symlink)")
        if [[ "$ta" == "$tb" ]]; then
            echo "/etc/$p matches the image"
        else
            echo "M /etc/$p (symlink target)"
            echo "  image: -> $ta"
            echo "  live:  -> $tb"
        fi
        return 0
    fi
    local pa pb
    pa=$(stat -c '%A %u:%g' "$a") pb=$(stat -c '%A %u:%g' "$b")
    local differs=0
    if [[ "$pa" != "$pb" ]]; then
        echo "M /etc/$p (permissions/ownership)"
        echo "  image: $pa"
        echo "  live:  $pb"
        differs=1
    fi
    if [[ -f "$a" && -f "$b" ]] && ! cmp -s "$a" "$b"; then
        [[ $differs -eq 1 ]] || echo "M /etc/$p"
        diff -u --label "image:/etc/$p" --label "live:/etc/$p" "$a" "$b" || true
        differs=1
    fi
    [[ $differs -eq 1 ]] || echo "/etc/$p matches the image"
}

restore_path() { # relative path; copies the pristine version over live /etc
    local p="$1" a="$PRISTINE/$1" b="$LIVE_ETC/$1"
    if [[ ! -e "$a" && ! -L "$a" ]]; then
        echo "snosi-etc-diff: /etc/$p: not in the image; remove it by hand if unwanted" >&2
        return 1
    fi
    if [[ -d "$a" && ! -L "$a" ]]; then
        # Directory entry: drift can only be permissions/ownership; never
        # touch its contents.
        mkdir -p "$b"
        chmod --reference="$a" "$b"
        chown --reference="$a" "$b"
    else
        if [[ -d "$b" && ! -L "$b" ]]; then
            echo "snosi-etc-diff: /etc/$p: live path is a directory but the image ships a non-directory; resolve by hand" >&2
            return 1
        fi
        mkdir -p "$(dirname "$b")"
        cp -a "$a" "$b.snosi-restore.$$"
        mv "$b.snosi-restore.$$" "$b"
    fi
    echo "restored /etc/$p from the image"
}

if [[ ${#PATHS[@]} -gt 0 ]]; then
    rc=0
    for raw in "${PATHS[@]}"; do
        p=$(normalize "$raw") || { rc=1; continue; }
        if [[ $RESTORE -eq 1 ]]; then
            restore_path "$p" || rc=1
        else
            show_path "$p" || rc=1
        fi
    done
    exit "$rc"
fi

# ---- list mode ------------------------------------------------------------

list_paths() { (cd "$1" && find . -mindepth 1 | LC_ALL=C sort | sed 's|^\./||'); }
pristine_list=$(list_paths "$PRISTINE")
live_list=$(list_paths "$LIVE_ETC")

emit() { # class path
    if [[ $MACHINE -eq 1 ]]; then
        printf '%s\t%s\n' "$1" "$2"
    else
        printf '%s /etc/%s\n' "$1" "$2"
    fi
}

found=0

# Deleted: in pristine, not in live.
while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    ignored "$p" && continue
    emit D "$p"; found=1
done < <(LC_ALL=C comm -23 <(echo "$pristine_list") <(echo "$live_list"))

# Added: in live, not in pristine.
if [[ $SHOW_ADDED -eq 1 ]]; then
    while IFS= read -r p; do
        [[ -n "$p" ]] || continue
        ignored "$p" && continue
        emit A "$p"; found=1
    done < <(LC_ALL=C comm -13 <(echo "$pristine_list") <(echo "$live_list"))
fi

# Modified: present in both, but different.
while IFS= read -r p; do
    [[ -n "$p" ]] || continue
    ignored "$p" && continue
    a="$PRISTINE/$p" b="$LIVE_ETC/$p"
    if [[ -L "$a" || -L "$b" ]]; then
        [[ "$(readlink "$a" 2>/dev/null)" == "$(readlink "$b" 2>/dev/null)" ]] && continue
    elif [[ -f "$a" && -f "$b" ]]; then
        pa=$(stat -c '%a:%u:%g' "$a") pb=$(stat -c '%a:%u:%g' "$b")
        if [[ "$pa" == "$pb" ]] && cmp -s "$a" "$b"; then continue; fi
    else
        # Directories (or matching special types): permissions only.
        pa=$(stat -c '%F:%a:%u:%g' "$a") pb=$(stat -c '%F:%a:%u:%g' "$b")
        [[ "$pa" == "$pb" ]] && continue
    fi
    emit M "$p"; found=1
done < <(LC_ALL=C comm -12 <(echo "$pristine_list") <(echo "$live_list"))

if [[ $MACHINE -eq 0 ]]; then
    if [[ $found -eq 0 ]]; then
        echo "live /etc matches the booted image (after ignores)"
    else
        cat <<'EOF'

For each entry:
  inspect  sudo snosi-etc-diff /etc/<path>     show the actual difference
  accept   add a glob to /etc/snosi/etc-diff.ignore (one per line, relative
           to /etc) if the change is intentional and should stop reporting
  revert   sudo snosi-etc-diff --restore /etc/<path>
EOF
    fi
fi
