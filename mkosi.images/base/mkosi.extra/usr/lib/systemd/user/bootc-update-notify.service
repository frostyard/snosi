# Per-user desktop notification for a staged OS update. Ack-gated per staged
# digest: notifies once per staged update, not per login or path trigger.
[Unit]
Description=Notify about a staged OS update pending reboot
After=graphical-session.target
ConditionPathExists=/run/snosi/update-staged

[Service]
Type=oneshot
ExecStart=/usr/libexec/bootc-update-notify

# No [Install]: triggered solely by bootc-update-notify.path (whose
# PathExists= also fires at session start when the semaphore already exists).
