[Transfer]
Features=coder
Verify=false

[Source]
Type=url-file
Path=https://repository.frostyard.org/ext/coder/
MatchPattern=coder_@v_%w_%a.raw.zst \
             coder_@v_%w_%a.raw.xz \
             coder_@v_%w_%a.raw.gz \
             coder_@v_%w_%a.raw

[Target]
Type=regular-file
Path=/var/lib/extensions.d/
MatchPattern=coder_@v_%w_%a.raw.zst \
             coder_@v_%w_%a.raw.xz \
             coder_@v_%w_%a.raw.gz \
             coder_@v_%w_%a.raw
CurrentSymlink=coder.raw
