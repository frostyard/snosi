[Transfer]
Features=debdev
Verify=false

[Source]
Type=url-file
Path=https://repository.frostyard.org/ext/debdev/
MatchPattern=debdev-@v-%w-%a.raw.zst \
             debdev-@v-%w-%a.raw.xz \
             debdev-@v-%w-%a.raw.gz \
             debdev-@v-%w-%a.raw

[Target]
Type=regular-file
Path=/var/lib/extensions.d/
MatchPattern=debdev-@v-%w-%a.raw.zst \
             debdev-@v-%w-%a.raw.xz \
             debdev-@v-%w-%a.raw.gz \
             debdev-@v-%w-%a.raw
CurrentSymlink=debdev.raw
