[Transfer]
Features=dev
Verify=false

[Source]
Type=url-file
Path=https://repository.frostyard.org/ext/dev/
MatchPattern=dev-@v-%w-%a.raw.zst \
             dev-@v-%w-%a.raw.xz \
             dev-@v-%w-%a.raw.gz \
             dev-@v-%w-%a.raw

[Target]
Type=regular-file
Path=/var/lib/extensions.d/
MatchPattern=dev-@v-%w-%a.raw.zst \
             dev-@v-%w-%a.raw.xz \
             dev-@v-%w-%a.raw.gz \
             dev-@v-%w-%a.raw
CurrentSymlink=dev.raw
