[Transfer]
Features=edge
Verify=false

[Source]
Type=url-file
Path=https://repository.frostyard.org/ext/edge/
MatchPattern=edge_@v_%w_%a.raw.zst \
             edge_@v_%w_%a.raw.xz \
             edge_@v_%w_%a.raw.gz \
             edge_@v_%w_%a.raw

[Target]
Type=regular-file
Path=/var/lib/extensions.d/
MatchPattern=edge_@v_%w_%a.raw.zst \
             edge_@v_%w_%a.raw.xz \
             edge_@v_%w_%a.raw.gz \
             edge_@v_%w_%a.raw
CurrentSymlink=edge.raw
