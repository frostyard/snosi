[Transfer]
Features=incus
Verify=false

[Source]
Type=url-file
Path=https://repository.frostyard.org/ext/incus/
MatchPattern=incus-@v-%w-%a.raw.zst \
             incus-@v-%w-%a.raw.xz \
             incus-@v-%w-%a.raw.gz \
             incus-@v-%w-%a.raw

[Target]
Type=regular-file
Path=/var/lib/extensions.d/
MatchPattern=incus-@v-%w-%a.raw.zst \
             incus-@v-%w-%a.raw.xz \
             incus-@v-%w-%a.raw.gz \
             incus-@v-%w-%a.raw
CurrentSymlink=incus.raw
