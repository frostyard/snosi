[Transfer]
Features=nix
Verify=false

[Source]
Type=url-file
Path=https://repository.frostyard.org/ext/nix/
MatchPattern=nix-@v-%w-%a.raw.zst \
             nix-@v-%w-%a.raw.xz \
             nix-@v-%w-%a.raw.gz \
             nix-@v-%w-%a.raw

[Target]
Type=regular-file
Path=/var/lib/extensions.d/
MatchPattern=nix-@v-%w-%a.raw.zst \
             nix-@v-%w-%a.raw.xz \
             nix-@v-%w-%a.raw.gz \
             nix-@v-%w-%a.raw
CurrentSymlink=nix.raw
