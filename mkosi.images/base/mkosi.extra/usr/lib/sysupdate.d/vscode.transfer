[Transfer]
Features=vscode
Verify=false

[Source]
Type=url-file
Path=https://repository.frostyard.org/ext/vscode/
MatchPattern=vscode_@v_%w_%a.raw.zst \
             vscode_@v_%w_%a.raw.xz \
             vscode_@v_%w_%a.raw.gz \
             vscode_@v_%w_%a.raw

[Target]
Type=regular-file
Path=/var/lib/extensions.d/
MatchPattern=vscode_@v_%w_%a.raw.zst \
             vscode_@v_%w_%a.raw.xz \
             vscode_@v_%w_%a.raw.gz \
             vscode_@v_%w_%a.raw
CurrentSymlink=vscode.raw
