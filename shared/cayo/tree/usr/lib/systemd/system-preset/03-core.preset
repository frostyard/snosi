disable ModemManager.service
disable cni-dhcp.service
disable iwd.service
disable rsync.service
disable wpa_supplicant.service
# Never prompt on the console at first boot (real first-boot semantics are
# active since machine-id ships as "uninitialized"). Locale/hostname/user
# setup is owned by the installer and first-setup, not systemd-firstboot.
disable systemd-firstboot.service