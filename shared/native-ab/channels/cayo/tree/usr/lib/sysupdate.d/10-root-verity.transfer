[Transfer]
ProtectVersion=%A
Verify=yes

[Source]
Type=url-file
Path=https://repository.frostyard.org/os/native/v1/cayo/x86-64/
MatchPattern=cayo-ab_@v_@u.root-verity.raw.xz

[Target]
Type=partition
Path=auto
MatchPattern=cayo_@v_v
MatchPartitionType=root-verity
PartitionFlags=0
ReadOnly=yes
InstancesMax=2
