[Transfer]
ProtectVersion=%A
Verify=yes

[Source]
Type=url-file
Path=https://repository.frostyard.org/os/native/v1/snow/x86-64/
MatchPattern=snow-ab_@v.efi

[Target]
Type=regular-file
Path=/EFI/Linux
PathRelativeTo=boot
MatchPattern=snow-ab_@v+@l-@d.efi
MatchPattern=snow-ab_@v+@l.efi
MatchPattern=snow-ab_@v.efi
Mode=0444
TriesLeft=3
TriesDone=0
InstancesMax=2
