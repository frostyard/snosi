#!/bin/bash

set -euo pipefail

echo "::group::Executing finalize"
trap 'echo "::endgroup::"' EXIT

# Clean folders for bootc — this runs chrooted into the image being built,
# not on a host; deleting these top-level dirs is the point.
# shellcheck disable=SC2114
rm -rf \
  /boot \
  /home \
  /root \
  /srv

mkdir /boot
mkdir /root
mkdir /home
mkdir /srv
mkdir /sysroot

# Create /nix as an empty mountpoint for the nix sysext bind-mount
mkdir -p /nix

# Golden-image machine-id: the literal "uninitialized" (machine-id(5)) makes
# the first boot of every install a TRUE systemd first boot — PID 1 applies
# unit presets, ConditionFirstBoot= fires, then a unique ID is generated and
# committed. The empty file shipped until 2026-07 only meant "generate an ID"
# and silently suppressed all first-boot semantics (mkosi's own default for a
# missing machine-id is "uninitialized" too; the old `touch` overrode it).
rm -f /etc/machine-id
echo "uninitialized" > /etc/machine-id

# Ship no unit enablement symlinks in /etc. mkosi ran `systemctl preset-all`
# (and `--global preset-all`) just before this script; PID 1 re-applies the
# same preset policy at first boot (real first boot, see machine-id above)
# and preset-global.service does the same for user units, recreating these
# symlinks in the live /etc as RUNTIME state. An admin's later `systemctl
# disable` then deletes a runtime-created path — harmless — instead of a
# path shipped in the image /etc, which breaks bootc's /etc merge at update
# finalize (see CLAUDE.md "Runtime service enablement changes are
# forbidden"). Kept in /etc: masks (-> /dev/null; presets never recreate
# masks) and linked units (targets outside the systemd unit dirs, e.g. the
# dracut-*.service links into /usr/lib/dracut — presets cannot recreate
# those either).
#
# A manifest of the stripped enablement symlinks ships in /usr so the
# first-boot parity test (test/tests/05-firstboot-presets.sh) can verify
# preset-all recreated every one of them. Excluded from the manifest
# (stripped, but presets will not — and need not — recreate them):
#   - ctrl-alt-del.target: not preset-managed; /usr ships the same alias
#   - display-manager.service: Debian display managers carry no Alias= in
#     [Install] (dpkg postinst creates this from
#     /etc/X11/default-display-manager), so presets cannot recreate it;
#     desktop trees ship it as a static /usr alias symlink instead
#   - wants/requires entries whose target unit is MASKED in the image
#     (preset-all skips masked units; a dangling wants for a masked unit
#     is inert anyway)
mkdir -p /usr/share/snosi
manifest=/usr/share/snosi/enablement-manifest.txt
: > "$manifest"
for scope in system user; do
    dir=/etc/systemd/$scope
    [[ -d $dir ]] || continue
    # Enablement symlinks inside .wants/.requires directories.
    find "$dir" -mindepth 2 -maxdepth 2 \
         \( -path '*.wants/*' -o -path '*.requires/*' \) -type l \
         -printf "$scope %P\n" >> "$manifest"
    # Top-level alias symlinks (targets inside the systemd unit dirs).
    # Masks (/dev/null) and linked units (targets elsewhere) are kept.
    find "$dir" -mindepth 1 -maxdepth 1 -type l \
         \( -lname '/usr/lib/systemd/*' -o -lname '/lib/systemd/*' \) \
         -printf "$scope %P\n" >> "$manifest"
done
sed -i -e '/^system ctrl-alt-del.target$/d' \
       -e '/^system display-manager.service$/d' "$manifest"
# Drop entries pointing at units masked in the image /etc.
for scope in system user; do
    find /etc/systemd/$scope -maxdepth 1 -type l -lname /dev/null \
         -printf '%f\n' 2>/dev/null | while read -r masked; do
        sed -i "\#^$scope .*/$masked\$#d" "$manifest"
    done
done
# C collation: the parity test comm(1)s against this file inside the guest.
LC_ALL=C sort -o "$manifest" "$manifest"

for scope in system user; do
    dir=/etc/systemd/$scope
    [[ -d $dir ]] || continue
    find "$dir" -mindepth 2 -maxdepth 2 \
         \( -path '*.wants/*' -o -path '*.requires/*' \) -type l -delete
    find "$dir" -mindepth 1 -maxdepth 1 -type l \
         \( -lname '/usr/lib/systemd/*' -o -lname '/lib/systemd/*' \) -delete
    find "$dir" -mindepth 1 -maxdepth 1 -type d \
         \( -name '*.wants' -o -name '*.requires' \) -empty -delete
done
echo "Stripped $(wc -l < "$manifest") enablement symlinks from /etc (recreated by presets at first boot)"

# Remove SSH Keys
rm -f /etc/ssh/ssh_host_*

# Compile GLib schemas
if command -v glib-compile-schemas >/dev/null 2>&1; then
    glib-compile-schemas /usr/share/glib-2.0/schemas/
fi

# Compile dconf databases
if command -v dconf >/dev/null 2>&1; then
    dconf update
fi

# Compute an update-interval bucket for a deb package from its changelog.
# Prints one of: daily, weekly, biweekly, monthly, quarterly, yearly.
get_update_bucket() {
  local pkg="$1"
  local changelog="/usr/share/doc/${pkg}/changelog.Debian.gz"
  if [[ ! -f "$changelog" ]]; then
    changelog="/usr/share/doc/${pkg}/changelog.gz"
  fi
  if [[ ! -f "$changelog" ]]; then
    echo "No changelog found to process"
    return 1
  fi

  local raw_dates
  raw_dates=$(zcat "$changelog" 2>/dev/null \
    | grep -E '^ -- .+>  ' \
    | head -n 10 \
    | sed -E 's/^ -- .+>  //') || true
  if [[ -z "$raw_dates" ]]; then
    echo "No dates in changelog found to process"
    return 1
  fi

  local epochs=()
  local d epoch
  while IFS= read -r d; do
    [[ -z "$d" ]] && continue
    if epoch=$(date -d "$d" +%s 2>/dev/null); then
      epochs+=("$epoch")
    fi
  done <<< "$raw_dates"

  if (( ${#epochs[@]} < 2 )); then
    echo "Not enough changelog history to determine update bucket"
    return 1
  fi

  local intervals=()
  local i diff
  for (( i=0; i < ${#epochs[@]} - 1; i++ )); do
    diff=$(( (epochs[i] - epochs[i+1]) / 86400 ))
    (( diff < 0 )) && diff=$(( -diff ))
    intervals+=("$diff")
  done

  local sorted
  sorted=$(printf '%s\n' "${intervals[@]}" | sort -n)
  local sorted_arr=()
  while IFS= read -r d; do sorted_arr+=("$d"); done <<< "$sorted"

  local n=${#sorted_arr[@]}
  local median
  if (( n % 2 == 1 )); then
    median=${sorted_arr[$(( n / 2 ))]}
  else
    median=$(( (sorted_arr[$(( n / 2 - 1 ))] + sorted_arr[$(( n / 2 ))]) / 2 ))
  fi

  if   (( median <= 3   )); then echo "daily"
  elif (( median <= 10  )); then echo "weekly"
  elif (( median <= 21  )); then echo "biweekly"
  elif (( median <= 52  )); then echo "monthly"
  elif (( median <= 180 )); then echo "quarterly"
  else                           echo "yearly"
  fi

  printf 'median=%s n=%s\n' "$median" "${#epochs[@]}" >&2
}

# Set file attributes for packages for chunkah to handle.
dpkg-query -W -f='${Package}\n' | while read -r pkgname; do
  echo "Setting file attributes for package: $pkgname (chunkah)"
  if bucket=$(get_update_bucket "$pkgname"); then
    echo "Using update-interval: $bucket"
  else
    echo "Could not determine update bucket, using default update-interval"
    bucket=""
  fi
  dpkg -L "$pkgname" | while read -r filepath; do
    if [[ -f "$filepath" ]]; then
      setfattr -n user.component -v "$pkgname" "$filepath" || true
      if [[ -n "$bucket" ]]; then
        setfattr -n user.update-interval -v "$bucket" "$filepath" || true
      fi
    fi
  done
done
